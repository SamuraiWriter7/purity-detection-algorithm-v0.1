{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/purity-assessment.schema.json",
  "title": "Purity Assessment Schema",
  "description": "Schema for validating purity assessment outputs in the Epicenter Preservation OS Protocol v0.1.",
  "type": "object",
  "required": ["purity_assessment"],
  "additionalProperties": false,
  "properties": {
    "purity_assessment": {
      "type": "object",
      "required": [
        "id",
        "epicenter_id",
        "assessed_at",
        "method",
        "version",
        "signals",
        "outputs",
        "review",
        "downstream_use"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "epicenter_id": {
          "type": "string",
          "minLength": 1
        },
        "assessed_at": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "enum": ["manual", "auto", "hybrid"]
        },
        "version": {
          "type": "string",
          "pattern": "^0\\.1\\.0$"
        },
        "assessor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "human_review",
                "automated_system",
                "multi_wing_review",
                "hybrid_review"
              ]
            },
            "system_id": {
              "type": "string"
            },
            "reviewer_notes": {
              "type": "string"
            }
          }
        },
        "signals": {
          "type": "object",
          "required": [
            "provenance_evidence_score",
            "author_declaration_score",
            "structural_originality_score",
            "revision_lineage_score",
            "citation_transparency_score",
            "ai_pattern_risk_score"
          ],
          "additionalProperties": false,
          "properties": {
            "provenance_evidence_score": {
              "$ref": "#/$defs/signal_score"
            },
            "author_declaration_score": {
              "$ref": "#/$defs/signal_score"
            },
            "structural_originality_score": {
              "$ref": "#/$defs/signal_score"
            },
            "revision_lineage_score": {
              "$ref": "#/$defs/signal_score"
            },
            "citation_transparency_score": {
              "$ref": "#/$defs/signal_score"
            },
            "ai_pattern_risk_score": {
              "$ref": "#/$defs/signal_score"
            }
          }
        },
        "outputs": {
          "type": "object",
          "required": [
            "origin_purity_score",
            "ai_generated_ratio",
            "warning_flags"
          ],
          "additionalProperties": false,
          "properties": {
            "origin_purity_score": {
              "$ref": "#/$defs/scored_output"
            },
            "ai_generated_ratio": {
              "$ref": "#/$defs/scored_output"
            },
            "warning_flags": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "missing_provenance",
                  "high_ai_pattern_similarity",
                  "declaration_conflict",
                  "low_confidence_score",
                  "recursive_synthetic_risk",
                  "origin_unclear",
                  "review_required",
                  "review_recommended",
                  "royalty_readiness_blocked"
                ]
              },
              "uniqueItems": true
            }
          }
        },
        "review": {
          "type": "object",
          "required": ["required", "recommended", "reason"],
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean"
            },
            "recommended": {
              "type": "boolean"
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "downstream_use": {
          "type": "object",
          "required": [
            "rag_indexing",
            "training_use",
            "royalty_readiness",
            "collapse_monitoring"
          ],
          "additionalProperties": false,
          "properties": {
            "rag_indexing": {
              "$ref": "#/$defs/downstream_permission"
            },
            "training_use": {
              "$ref": "#/$defs/downstream_permission"
            },
            "royalty_readiness": {
              "type": "object",
              "required": ["status", "notes"],
              "additionalProperties": false,
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "not_ready",
                    "review_ready",
                    "ready",
                    "blocked",
                    "disputed"
                  ]
                },
                "notes": {
                  "type": "string"
                }
              }
            },
            "collapse_monitoring": {
              "type": "object",
              "required": ["include", "notes"],
              "additionalProperties": false,
              "properties": {
                "include": {
                  "type": "boolean"
                },
                "notes": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "signal_score": {
      "type": "object",
      "required": ["value", "basis"],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "basis": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "scored_output": {
      "type": "object",
      "required": ["value", "confidence", "interpretation"],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "interpretation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "downstream_permission": {
      "type": "object",
      "required": ["allowed", "notes"],
      "additionalProperties": false,
      "properties": {
        "allowed": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "enum": ["conditional", "unknown", "requires_permission"]
            }
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
